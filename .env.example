# ChatFlow Dashboard — environment variables
# Copy to .env.local and fill in values

# Backend API URL (Render free tier URL once deployed)
VITE_API_URL=https://chatflow-api.onrender.com

# Paddle Billing (sandbox until launch)
# Get from: Paddle Dashboard → Developer Tools → Authentication
VITE_PADDLE_CLIENT_TOKEN=test_xxxxx
VITE_PADDLE_ENV=sandbox

# Paddle Price IDs (from Paddle Dashboard → Catalog → Prices)
VITE_PADDLE_STARTER_PRICE_ID=pri_xxxxxxxxxxxx
VITE_PADDLE_PRO_PRICE_ID=pri_xxxxxxxxxxxx
